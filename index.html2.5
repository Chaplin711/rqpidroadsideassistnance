<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rapid Roadside Assistance | 24/7 Roadside Near Me</title>
<meta name="description" content="24/7 roadside assistance for lockouts, jump starts, towing, and flat tires. Fast roadside service near you.">
<meta name="keywords" content="roadside assistance near me, tow truck, jump start service, car lockout, flat tire help">
<style>
body{font-family:Arial;margin:0;background:#f4f4f4;color:#222}
header{background:#111;color:#fff;padding:20px;text-align:center}
nav{background:#222;padding:12px;text-align:center}
nav a{color:#fff;margin:0 15px;text-decoration:none;font-weight:bold}
section{padding:50px 20px;max-width:1100px;margin:auto}
.hero{background:#333;color:white;text-align:center;padding:90px 20px}
.services{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;margin-top:20px}
.card{background:white;padding:20px;border-radius:12px;box-shadow:0 0 10px rgba(0,0,0,0.1)}
.contact{background:#fff;padding:25px;border-radius:12px;box-shadow:0 0 10px rgba(0,0,0,0.1)}
button{background:#28a745;color:white;padding:12px 22px;border:none;border-radius:6px;font-size:16px;cursor:pointer}
button:hover{opacity:.9}
.call-btn{background:#e63946;font-size:20px;margin-top:15px}
.payments button{margin:10px}
input,textarea{width:100%;padding:10px;margin-top:8px;border-radius:6px;border:1px solid #ccc}
footer{background:#111;color:#fff;text-align:center;padding:20px;margin-top:40px}
.dashboard{background:#fff;padding:20px;border-radius:12px;margin-top:30px}
table{width:100%;border-collapse:collapse}
th,td{padding:10px;border-bottom:1px solid #ddd;text-align:left}
.review-box{background:#fff;padding:20px;border-radius:12px}
.pricing{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin-top:20px}
.price-card{background:white;padding:20px;border-radius:10px;text-align:center;box-shadow:0 0 10px rgba(0,0,0,0.1)}
.qr{width:180px;margin-top:15px}
.chatbot{position:fixed;bottom:20px;right:20px;background:white;width:260px;border-radius:10px;box-shadow:0 0 10px rgba(0,0,0,0.2);overflow:hidden}
.chat-header{background:#111;color:white;padding:10px;text-align:center}
.chat-body{height:200px;overflow-y:auto;padding:10px;font-size:14px}
.chat-input{display:flex}
.chat-input input{flex:1;border:none;padding:8px}
.chat-input button{border-radius:0}
.tracker{background:#fff;padding:20px;border-radius:12px}
</style>
</head>
<body>

<header>
<h1>Rapid Roadside Assistance</h1>
<p>24/7 Emergency Roadside Help Near You • Call 919-793-3560 or 240-350-7360</p>
</header>

<nav>
<a href="#services">Services</a>
<a href="#pricing">Pricing</a>
<a href="#location">Send Location</a>
<a href="#contact">Request Help</a>
<a href="#tracker">Tow Tracking</a>
<a href="#payment">Pay</a>
<a href="#reviews">Reviews</a>
</nav>

<section class="hero">
<h2>Flat Tire • Dead Battery • Lockout • Fuel Delivery</h2>
<p>Immediate roadside assistance available</p>
<a href="tel:+19197933560"><button class="call-btn">📞 CALL FOR HELP</button></a>
</section>

<section id="services">
<h2>Our Services</h2>
<div class="services">
<div class="card"><h3>Battery Jumpstart</h3><p>Emergency battery boost anywhere.</p></div>
<div class="card"><h3>Flat Tire Change</h3><p>Professional tire replacement.</p></div>
<div class="card"><h3>Vehicle Lockout</h3><p>Fast car unlock service.</p></div>
<div class="card"><h3>Fuel Delivery</h3><p>Gas delivered to your location.</p></div>
<div class="card"><h3>Towing</h3><p>Emergency tow service.</p></div>
</div>
</section>

<section id="pricing">
<h2>Quick Service Pricing</h2>
<div class="pricing">
<div class="price-card"><h3>Jump Start</h3><p>$75</p><button onclick="payService('Jump Start',75)">Pay</button></div>
<div class="price-card"><h3>Tire Change</h3><p>$80</p><button onclick="payService('Tire Change',80)">Pay</button></div>
<div class="price-card"><h3>Lockout</h3><p>$90</p><button onclick="payService('Lockout',90)">Pay</button></div>
<div class="price-card"><h3>Fuel Delivery</h3><p>$85</p><button onclick="payService('Fuel Delivery',85)">Pay</button></div>
</div>
</section>

<section id="location">
<h2>Send Your GPS Location</h2>
<button onclick="getLocation()">📍 SEND MY LOCATION</button>
<p id="locationOutput"></p>

<h3>Search Service Area</h3>
<input type="text" placeholder="Enter your city" id="citySearch">
<button onclick="searchCity()">Find Service</button>
<p id="cityResult"></p>
</section>

<section id="contact">
<h2>Emergency Service Request</h2>
<div class="contact">
<form id="helpForm">
<label>Name</label>
<input type="text" id="name" required>

<label>Phone</label>
<input type="tel" id="phone" required>

<label>Vehicle Problem</label>
<textarea id="issue" required></textarea>

<button type="submit">Request Technician</button>
</form>
</div>
</section>

<section id="tracker">
<h2>Tow Truck Tracking</h2>
<div class="tracker">
<p>Technician Status:</p>
<p id="towStatus">Dispatching driver...</p>
<button onclick="simulateTow()">Update Status</button>
</div>
</section>

<section>
<h2>Dispatcher Dashboard</h2>
<div class="dashboard">
<table id="requestsTable">
<tr><th>Name</th><th>Phone</th><th>Issue</th></tr>
</table>
</div>
</section>

<section id="payment">
<h2>Pay for Service</h2>

<h3>Cash App</h3>
<p>Send payment to: <b>$Island711</b></p>
<a href="https://cash.app/$Island711" target="_blank">
<button>Pay with Cash App</button>
</a>

<img class="qr" src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=https://cash.app/$Island711">

<div class="payments">
<button onclick="window.open('https://paypal.com')">PayPal</button>
<button onclick="window.open('https://buy.stripe.com')">Credit Card</button>
</div>
</section>

<section id="reviews">
<h2>Customer Reviews</h2>
<div class="review-box">
<p>⭐⭐⭐⭐⭐ Fast roadside service and very professional.</p>
<p>⭐⭐⭐⭐⭐ They arrived quickly and got my car started.</p>
<iframe src="https://www.google.com/maps?q=roadside+assistance&output=embed" width="100%" height="350"></iframe>
</div>
</section>

<footer>
<p>© 2026 Rapid Roadside Assistance | 24/7 Emergency Service</p>
</footer>

<div class="chatbot">
<div class="chat-header">Roadside Assistant</div>
<div class="chat-body" id="chatBody">Hello 👋 Need roadside help?</div>
<div class="chat-input">
<input id="chatInput" placeholder="Type here">
<button onclick="chatSend()">Send</button>
</div>
</div>

<script>

function getLocation(){
if(navigator.geolocation){
navigator.geolocation.getCurrentPosition(function(position){
let lat=position.coords.latitude
let lon=position.coords.longitude
let link=`https://maps.google.com/?q=${lat},${lon}`
document.getElementById("locationOutput").innerHTML=
"Location detected: <a href='"+link+"' target='_blank'>Open Map</a>";
})
}
}

function searchCity(){
let city=document.getElementById("citySearch").value
if(city){
document.getElementById("cityResult").innerText="Service available near "+city
}
}

function simulateTow(){
const statuses=["Driver Assigned","Driver En Route","5 Minutes Away","Arrived"]
let random=statuses[Math.floor(Math.random()*statuses.length)]
document.getElementById("towStatus").innerText=random
}

function payService(service,price){
alert(service+" selected. Price: $"+price)
window.open("https://cash.app/$Island711")
}

const form=document.getElementById("helpForm")
const table=document.getElementById("requestsTable")

form.addEventListener("submit",function(e){
e.preventDefault()

let name=document.getElementById("name").value
let phone=document.getElementById("phone").value
let issue=document.getElementById("issue").value

let row=table.insertRow()
row.insertCell(0).innerText=name
row.insertCell(1).innerText=phone
row.insertCell(2).innerText=issue

let sms=`Roadside Request:%0A${name}%0A${phone}%0A${issue}`
window.open(`sms:+19197933560?body=${sms}`)

form.reset()
alert("Request sent. Technician notified.")
})

function chatSend(){
let input=document.getElementById("chatInput")
let body=document.getElementById("chatBody")
let msg=input.value
if(msg){
body.innerHTML+="<br><b>You:</b> "+msg
body.innerHTML+="<br><b>Bot:</b> Please call our dispatch or submit the help form above.";
input.value=""
body.scrollTop=body.scrollHeight
}
}

</script>

</body>
</html>
